{
    "name": "indigo-dyeing-backend",
    "version": "0.1.0",
    "description": "Backend API for Indigo Dyeing app",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "knex migrate:latest",
        "db:seed": "knex seed:run",
        "db:rollback": "knex migrate:rollback",
        "lint": "eslint src --ext ts"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.0",
        "express-rate-limit": "^8.4.1",
        "express-validator": "^7.0.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.1.0",
        "pg": "^8.11.0",
        "stripe": "^14.0.0",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.0",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jsonwebtoken": "^9.0.0",
        "@types/node": "^20.0.0",
        "@types/uuid": "^10.0.0",
        "eslint": "^8.50.0",
        "tsx": "^4.0.0",
        "typescript": "^6.0.0"
    }
}
